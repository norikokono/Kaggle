    "%%writefile claim4_toy_comparison.py\n",
    "\n",
    "# /// script\n",
    "# dependencies = [\"torch\", \"numpy\"]\n",
    "# ///\n",
    "\"\"\"\n",
    "Claim 4 -- toy-scale head-to-head comparison on the paper's exact\n",
    "8-agent, 10-action nonlinear MatGame setting (Table 1). Vectorized\n",
    "version: candidate generation uses precomputed batched tensor masks\n",
    "instead of per-candidate Python loops, since the naive version is too\n",
    "slow for 2000 decisions.\n",
    "\"\"\"\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import numpy as np\n",
    "\n",
    "\n",
    "class MatgameNonZeroEnv:\n",
    "    def __init__(self, n_agents=8, n_actions=10, reward_type=\"nonlinear\",\n",
    "                 noise_std=2.0, noise_uniform_range=3.0, seed=None):\n",
    "        self.n_agents = n_agents\n",
    "        self.n_actions = n_actions\n",
    "        self.reward_type = reward_type\n",
    "        self.noise_std = noise_std\n",
    "        self.noise_uniform_range = noise_uniform_range\n",
    "        self._rng = np.random.default_rng(seed)\n",
    "\n",
    "    def joint_reward(self, actions):\n",
    "        base = float(np.sum(actions))\n",
    "        if self.reward_type == \"linear\":\n",
    "            return base\n",
    "        u = self._rng.normal(0.0, self.noise_std)\n",
    "        v = self._rng.uniform(-self.noise_uniform_range, self.noise_uniform_range)\n",
    "        return base + u + v\n",
    "\n",
    "\n",
    "class VectorizedProposer:\n",
    "    def __init__(self, n_agents, n_actions, c=1.0, alpha=1.0):\n",
    "        self.n_agents, self.n_actions = n_agents, n_actions\n",
    "        self.nd = n_agents * n_actions\n",
    "        self.c, self.alpha = c, alpha\n",
    "\n",
    "        rows1 = n_agents * n_actions\n",
    "        self.agent1 = torch.zeros(rows1, dtype=torch.long)\n",
    "        self.action1 = torch.zeros(rows1, dtype=torch.long)\n",
    "        self.block_mask1 = torch.zeros(rows1, self.nd)\n",
    "        self.target1 = torch.zeros(rows1, self.nd)\n",
    "        r = 0\n",
    "        for i in range(n_agents):\n",
    "            for j in range(n_actions):\n",
    "                self.agent1[r], self.action1[r] = i, j\n",
    "                self.block_mask1[r, i * n_actions:(i + 1) * n_actions] = 1.0\n",
    "                self.target1[r, i * n_actions + j] = 1.0\n",
    "                r += 1\n",
    "\n",
    "        pairs = [(i, j) for i in range(n_agents) for j in range(i + 1, n_agents)]\n",
    "        rows2 = len(pairs) * n_actions * n_actions\n",
    "        self.pair_i = torch.zeros(rows2, dtype=torch.long)\n",
    "        self.pair_j = torch.zeros(rows2, dtype=torch.long)\n",
    "        self.action_i = torch.zeros(rows2, dtype=torch.long)\n",
    "        self.action_j = torch.zeros(rows2, dtype=torch.long)\n",
    "        self.block_mask2 = torch.zeros(rows2, self.nd)\n",
    "        self.target2 = torch.zeros(rows2, self.nd)\n",
    "        r = 0\n",
    "        for (i, j) in pairs:\n",
    "            for ai in range(n_actions):\n",
    "                for aj in range(n_actions):\n",
    "                    self.pair_i[r], self.pair_j[r] = i, j\n",
    "                    self.action_i[r], self.action_j[r] = ai, aj\n",
    "                    self.block_mask2[r, i * n_actions:(i + 1) * n_actions] = 1.0\n",
    "                    self.block_mask2[r, j * n_actions:(j + 1) * n_actions] = 1.0\n",
    "                    self.target2[r, i * n_actions + ai] = 1.0\n",
    "                    self.target2[r, j * n_actions + aj] = 1.0\n",
    "                    r += 1\n",
    "\n",
    "    def one_hot(self, agent_actions):\n",
    "        agent_actions = torch.as_tensor(agent_actions, dtype=torch.long)\n",
    "        oh = torch.nn.functional.one_hot(agent_actions, num_classes=self.n_actions)\n",
    "        return oh.reshape(-1).float()\n",
    "\n",
    "    def eta(self, theta, a_batch):\n",
    "        return self.c * torch.asinh(self.alpha * (theta.unsqueeze(0) * a_batch).sum(dim=-1))\n",
    "\n",
    "    def best_candidate(self, theta, cur_enc, current_actions):\n",
    "        cur_eta = self.eta(theta, cur_enc.unsqueeze(0)).item()\n",
    "\n",
    "        cand1 = cur_enc.unsqueeze(0) * (1 - self.block_mask1) + self.target1\n",
    "        eta1 = self.eta(theta, cand1)\n",
    "        current_action1 = torch.as_tensor(current_actions)[self.agent1]\n",
    "        self_mask1 = (self.action1 == current_action1)\n",
    "        eta1 = eta1.masked_fill(self_mask1, -float(\"inf\"))\n",
    "        delta1 = eta1 - cur_eta\n",
    "        best1_val, best1_idx = delta1.max(dim=0)\n",
    "\n",
    "        cand2 = cur_enc.unsqueeze(0) * (1 - self.block_mask2) + self.target2\n",
    "        eta2 = self.eta(theta, cand2)\n",
    "        cur_ai = torch.as_tensor(current_actions)[self.pair_i]\n",
    "        cur_aj = torch.as_tensor(current_actions)[self.pair_j]\n",
    "        self_mask2 = (self.action_i == cur_ai) | (self.action_j == cur_aj)\n",
    "        eta2 = eta2.masked_fill(self_mask2, -float(\"inf\"))\n",
    "        delta2 = eta2 - cur_eta\n",
    "        best2_val, best2_idx = delta2.max(dim=0)\n",
    "\n",
    "        if best1_val.item() >= best2_val.item():\n",
    "            agent_idx, new_action = self.agent1[best1_idx].item(), self.action1[best1_idx].item()\n",
    "            candidate_actions = current_actions.copy()\n",
    "            candidate_actions[agent_idx] = new_action\n",
    "        else:\n",
    "            i, j = self.pair_i[best2_idx].item(), self.pair_j[best2_idx].item()\n",
    "            ai, aj = self.action_i[best2_idx].item(), self.action_j[best2_idx].item()\n",
    "            candidate_actions = current_actions.copy()\n",
    "            candidate_actions[i], candidate_actions[j] = ai, aj\n",
    "\n",
    "        return candidate_actions\n",
    "\n",
    "\n",
    "def fit_surrogate(env, n_agents, n_actions, n_samples=4000, n_epochs=1500, rng=None):\n",
    "    actions = rng.integers(0, n_actions, size=(n_samples, n_agents))\n",
    "    rewards = torch.tensor([env.joint_reward(a) for a in actions], dtype=torch.float32)\n",
    "    onehots = torch.nn.functional.one_hot(torch.tensor(actions, dtype=torch.long), num_classes=n_actions)\n",
    "    a_enc = onehots.reshape(n_samples, -1).float()\n",
    "\n",
    "    nd = n_agents * n_actions\n",
    "    theta = nn.Parameter(torch.zeros(nd))\n",
    "    log_c, log_alpha = nn.Parameter(torch.zeros(())), nn.Parameter(torch.zeros(()))\n",
    "    opt = torch.optim.Adam([theta, log_c, log_alpha], lr=0.05)\n",
    "    sched = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=n_epochs)\n",
    "\n",
    "    for _ in range(n_epochs):\n",
    "        opt.zero_grad()\n",
    "        pred = torch.exp(log_c) * torch.asinh(torch.exp(log_alpha) * (theta * a_enc).sum(dim=-1))\n",
    "        loss = ((pred - rewards) ** 2).mean()\n",
    "        loss.backward()\n",
    "        opt.step()\n",
    "        sched.step()\n",
    "    return theta.detach()\n",
    "\n",
    "\n",
    "def nonzero_style_decision(env, proposer, theta, budget, rng):\n",
    "    n_agents, n_actions = env.n_agents, env.n_actions\n",
    "    current = rng.integers(0, n_actions, size=n_agents)\n",
    "    best_reward = env.joint_reward(current)\n",
    "    evals_used = 1\n",
    "\n",
    "    while evals_used < budget:\n",
    "        cur_enc = proposer.one_hot(current)\n",
    "        candidate_actions = proposer.best_candidate(theta, cur_enc, current)\n",
    "        real_reward = env.joint_reward(candidate_actions)\n",
    "        evals_used += 1\n",
    "\n",
    "        if real_reward > best_reward:\n",
    "            current = candidate_actions\n",
    "            best_reward = real_reward\n",
    "        else:\n",
    "            break\n",
    "\n",
    "    return best_reward\n",
    "\n",
    "\n",
    "def mazero_style_decision(env, budget, rng):\n",
    "    best_reward = -float(\"inf\")\n",
    "    for _ in range(budget):\n",
    "        actions = rng.integers(0, env.n_actions, size=env.n_agents)\n",
    "        r = env.joint_reward(actions)\n",
    "        if r > best_reward:\n",
    "            best_reward = r\n",
    "    return best_reward\n",
    "\n",
    "\n",
    "def main():\n",
    "    print(\"=\" * 70)\n",
    "    print(\"NonZero reproduction -- Claim 4 toy comparison (vectorized)\")\n",
    "    print(\"Setting: 8 agents, 10 actions, nonlinear (Table 1's hardest config)\")\n",
    "    print(\"2000 sequential decisions, equal real-eval budget per decision\")\n",
    "    print(\"=\" * 70)\n",
    "\n",
    "    n_agents, n_actions = 8, 10\n",
    "    n_steps = 2000\n",
    "    budget_per_step = 15\n",
    "\n",
    "    rng_fit = np.random.default_rng(0)\n",
    "    env_fit = MatgameNonZeroEnv(n_agents=n_agents, n_actions=n_actions,\n",
    "                                 reward_type=\"nonlinear\", seed=1)\n",
    "    theta = fit_surrogate(env_fit, n_agents, n_actions, rng=rng_fit)\n",
    "    proposer = VectorizedProposer(n_agents, n_actions)\n",
    "    print(f\"\\nSurrogate fit complete. Candidate masks precomputed \"\n",
    "          f\"({proposer.block_mask1.shape[0]} first-order + \"\n",
    "          f\"{proposer.block_mask2.shape[0]} second-order candidates/decision).\")\n",
    "\n",
    "    nonzero_rewards, mazero_rewards = [], []\n",
    "    for step in range(n_steps):\n",
    "        env_a = MatgameNonZeroEnv(n_agents=n_agents, n_actions=n_actions,\n",
    "                                   reward_type=\"nonlinear\", seed=5000 + step)\n",
    "        rng_a = np.random.default_rng(3000 + step)\n",
    "        nonzero_rewards.append(nonzero_style_decision(env_a, proposer, theta, budget_per_step, rng_a))\n",
    "\n",
    "        env_b = MatgameNonZeroEnv(n_agents=n_agents, n_actions=n_actions,\n",
    "                                   reward_type=\"nonlinear\", seed=5000 + step)\n",
    "        rng_b = np.random.default_rng(3000 + step)\n",
    "        mazero_rewards.append(mazero_style_decision(env_b, budget_per_step, rng_b))\n",
    "\n",
    "        if (step + 1) % 400 == 0:\n",
    "            print(f\"  ...{step + 1}/{n_steps} decisions completed\")\n",
    "\n",
    "    nz_mean, nz_std = np.mean(nonzero_rewards), np.std(nonzero_rewards)\n",
    "    mz_mean, mz_std = np.mean(mazero_rewards), np.std(mazero_rewards)\n",
    "    improvement = (nz_mean - mz_mean) / abs(mz_mean) * 100\n",
    "\n",
    "    print(f\"\\n[Results over {n_steps} decisions, budget={budget_per_step}/decision]\")\n",
    "    print(f\"  NonZero-style (guided proposal):  {nz_mean:.2f} +/- {nz_std:.2f}\")\n",
    "    print(f\"  MAZero-style (random sampled):    {mz_mean:.2f} +/- {mz_std:.2f}\")\n",
    "    print(f\"  Improvement: {improvement:+.1f}%\")\n",
    "\n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"SUMMARY\")\n",
    "    if nz_mean > mz_mean:\n",
    "        print(f\"  PASS (toy scale): NonZero-style guided proposal outperforms\")\n",
    "        print(f\"  MAZero-style random sampling by {improvement:.1f}% under equal budget.\")\n",
    "    else:\n",
    "        print(f\"  FAIL: guided proposal did NOT outperform the baseline.\")\n",
    "    print(\"=\" * 70)\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()"
   ]

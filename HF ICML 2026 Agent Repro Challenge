    "%%writefile claim1_mechanism_test.py\n",
    "# /// script\n",
    "# dependencies = [\"torch\", \"numpy\"]\n",
    "# ///\n",
    "\"\"\"\n",
    "Claim 1 -- toy-scale test of NonZero's actual proposal mechanism.\n",
    "\n",
    "The paper's real claim isn't just \"the surrogate can fit rewards\" -- it's\n",
    "that using the surrogate's first-order (single-agent) and second-order\n",
    "(two-agent) difference operators to PROPOSE candidate action changes finds\n",
    "good joint actions more efficiently than enumerating/random-sampling the\n",
    "full joint-action space (Section 3, Section 3.1).\n",
    "\n",
    "This script tests that directly: under an EQUAL evaluation budget, does\n",
    "NonUCT-style guided local search find better joint actions than random\n",
    "sampling, on the 8-agent/10-action nonlinear MatGame environment?\n",
    "\"\"\"\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import numpy as np\n",
    "\n",
    "\n",
    "class MatgameNonZeroEnv:\n",
    "    def __init__(self, n_agents=8, n_actions=10, reward_type=\"nonlinear\",\n",
    "                 noise_std=2.0, noise_uniform_range=3.0, seed=None):\n",
    "        self.n_agents = n_agents\n",
    "        self.n_actions = n_actions\n",
    "        self.reward_type = reward_type\n",
    "        self.noise_std = noise_std\n",
    "        self.noise_uniform_range = noise_uniform_range\n",
    "        self._rng = np.random.default_rng(seed)\n",
    "\n",
    "    def joint_reward(self, actions):\n",
    "        base = float(np.sum(actions))\n",
    "        if self.reward_type == \"linear\":\n",
    "            return base\n",
    "        u = self._rng.normal(0.0, self.noise_std)\n",
    "        v = self._rng.uniform(-self.noise_uniform_range, self.noise_uniform_range)\n",
    "        return base + u + v\n",
    "\n",
    "\n",
    "class AsinhGLMSurrogate:\n",
    "    def __init__(self, n_agents, n_actions, c=1.0, alpha=1.0):\n",
    "        self.n_agents, self.n_actions = n_agents, n_actions\n",
    "        self.nd = n_agents * n_actions\n",
    "        self.c, self.alpha = c, alpha\n",
    "\n",
    "    def one_hot(self, agent_actions):\n",
    "        agent_actions = torch.as_tensor(agent_actions, dtype=torch.long)\n",
    "        oh = torch.nn.functional.one_hot(agent_actions, num_classes=self.n_actions)\n",
    "        return oh.reshape(*agent_actions.shape[:-1], self.nd).float()\n",
    "\n",
    "    def eta(self, theta, a):\n",
    "        return self.c * torch.asinh(self.alpha * (theta * a).sum(dim=-1))\n",
    "\n",
    "    def neighbor(self, a, agent_idx, new_action):\n",
    "        a = a.clone()\n",
    "        s = agent_idx * self.n_actions\n",
    "        a[..., s:s + self.n_actions] = 0.0\n",
    "        a[..., s + new_action] = 1.0\n",
    "        return a\n",
    "\n",
    "    def neighbor_pair(self, a, agent_i, action_i, agent_j, action_j):\n",
    "        a = self.neighbor(a, agent_i, action_i)\n",
    "        a = self.neighbor(a, agent_j, action_j)\n",
    "        return a\n",
    "\n",
    "\n",
    "def fit_surrogate(env, surrogate, n_samples=4000, n_epochs=1500, rng=None):\n",
    "    actions = rng.integers(0, env.n_actions, size=(n_samples, env.n_agents))\n",
    "    rewards = torch.tensor([env.joint_reward(a) for a in actions], dtype=torch.float32)\n",
    "    a_enc = surrogate.one_hot(torch.tensor(actions, dtype=torch.long))\n",
    "\n",
    "    theta = nn.Parameter(torch.zeros(surrogate.nd))\n",
    "    log_c, log_alpha = nn.Parameter(torch.zeros(())), nn.Parameter(torch.zeros(()))\n",
    "    opt = torch.optim.Adam([theta, log_c, log_alpha], lr=0.05)\n",
    "    sched = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=n_epochs)\n",
    "\n",
    "    def predict(a_batch):\n",
    "        return torch.exp(log_c) * torch.asinh(torch.exp(log_alpha) * (theta * a_batch).sum(dim=-1))\n",
    "\n",
    "    for _ in range(n_epochs):\n",
    "        opt.zero_grad()\n",
    "        loss = ((predict(a_enc) - rewards) ** 2).mean()\n",
    "        loss.backward()\n",
    "        opt.step()\n",
    "        sched.step()\n",
    "    return theta.detach()\n",
    "\n",
    "\n",
    "def nonuct_guided_search(env, surrogate, theta, eval_budget, rng):\n",
    "    n_agents, n_actions = env.n_agents, env.n_actions\n",
    "    current = rng.integers(0, n_actions, size=n_agents)\n",
    "    best_reward = env.joint_reward(current)\n",
    "    evals_used = 1\n",
    "\n",
    "    while evals_used < eval_budget:\n",
    "        cur_enc = surrogate.one_hot(torch.tensor(current, dtype=torch.long))\n",
    "        cur_eta = surrogate.eta(theta, cur_enc).item()\n",
    "\n",
    "        best_candidate, best_delta, best_kind = None, -float(\"inf\"), None\n",
    "        for agent_idx in range(n_agents):\n",
    "            for new_action in range(n_actions):\n",
    "                if new_action == current[agent_idx]:\n",
    "                    continue\n",
    "                cand_enc = surrogate.neighbor(cur_enc, agent_idx, new_action)\n",
    "                delta = (surrogate.eta(theta, cand_enc) - cur_eta).item()\n",
    "                if delta > best_delta:\n",
    "                    best_delta, best_candidate, best_kind = delta, (agent_idx, new_action), \"first\"\n",
    "\n",
    "        for i in range(n_agents):\n",
    "            for j in range(i + 1, n_agents):\n",
    "                for ai in range(n_actions):\n",
    "                    if ai == current[i]:\n",
    "                        continue\n",
    "                    for aj in range(n_actions):\n",
    "                        if aj == current[j]:\n",
    "                            continue\n",
    "                        cand_enc = surrogate.neighbor_pair(cur_enc, i, ai, j, aj)\n",
    "                        delta = (surrogate.eta(theta, cand_enc) - cur_eta).item()\n",
    "                        if delta > best_delta:\n",
    "                            best_delta, best_candidate, best_kind = delta, (i, ai, j, aj), \"second\"\n",
    "\n",
    "        if best_candidate is None or evals_used >= eval_budget:\n",
    "            break\n",
    "\n",
    "        candidate_actions = current.copy()\n",
    "        if best_kind == \"first\":\n",
    "            agent_idx, new_action = best_candidate\n",
    "            candidate_actions[agent_idx] = new_action\n",
    "        else:\n",
    "            i, ai, j, aj = best_candidate\n",
    "            candidate_actions[i] = ai\n",
    "            candidate_actions[j] = aj\n",
    "\n",
    "        real_reward = env.joint_reward(candidate_actions)\n",
    "        evals_used += 1\n",
    "\n",
    "        if real_reward > best_reward:\n",
    "            current = candidate_actions\n",
    "            best_reward = real_reward\n",
    "        else:\n",
    "            break\n",
    "\n",
    "    return best_reward, evals_used\n",
    "\n",
    "\n",
    "def random_search(env, eval_budget, rng):\n",
    "    best_reward = -float(\"inf\")\n",
    "    for _ in range(eval_budget):\n",
    "        actions = rng.integers(0, env.n_actions, size=env.n_agents)\n",
    "        r = env.joint_reward(actions)\n",
    "        if r > best_reward:\n",
    "            best_reward = r\n",
    "    return best_reward\n",
    "\n",
    "\n",
    "def main():\n",
    "    print(\"=\" * 70)\n",
    "    print(\"NonZero reproduction -- Claim 1 mechanism test (toy scale)\")\n",
    "    print(\"Testing: does surrogate-guided proposal beat random search\")\n",
    "    print(\"under an EQUAL real-environment evaluation budget?\")\n",
    "    print(\"=\" * 70)\n",
    "\n",
    "    n_trials = 200\n",
    "    eval_budget = 15\n",
    "\n",
    "    rng_fit = np.random.default_rng(0)\n",
    "    env_fit = MatgameNonZeroEnv(n_agents=8, n_actions=10, reward_type=\"nonlinear\", seed=1)\n",
    "    surrogate = AsinhGLMSurrogate(8, 10)\n",
    "    theta = fit_surrogate(env_fit, surrogate, rng=rng_fit)\n",
    "    print(f\"\\nSurrogate fit complete (theta trained on 4000 samples).\")\n",
    "\n",
    "    guided_rewards, random_rewards = [], []\n",
    "    for trial in range(n_trials):\n",
    "        rng = np.random.default_rng(1000 + trial)\n",
    "        env = MatgameNonZeroEnv(n_agents=8, n_actions=10, reward_type=\"nonlinear\", seed=2000 + trial)\n",
    "\n",
    "        g_reward, g_evals = nonuct_guided_search(env, surrogate, theta, eval_budget, rng)\n",
    "        guided_rewards.append(g_reward)\n",
    "\n",
    "        env2 = MatgameNonZeroEnv(n_agents=8, n_actions=10, reward_type=\"nonlinear\", seed=2000 + trial)\n",
    "        rng2 = np.random.default_rng(1000 + trial)\n",
    "        r_reward = random_search(env2, eval_budget, rng2)\n",
    "        random_rewards.append(r_reward)\n",
    "\n",
    "    guided_mean, guided_std = np.mean(guided_rewards), np.std(guided_rewards)\n",
    "    random_mean, random_std = np.mean(random_rewards), np.std(random_rewards)\n",
    "    improvement = (guided_mean - random_mean) / abs(random_mean) * 100\n",
    "\n",
    "    print(f\"\\n[Results over {n_trials} trials, eval_budget={eval_budget}]\")\n",
    "    print(f\"  Surrogate-guided search: {guided_mean:.2f} +/- {guided_std:.2f}\")\n",
    "    print(f\"  Random search (baseline): {random_mean:.2f} +/- {random_std:.2f}\")\n",
    "    print(f\"  Improvement: {improvement:+.1f}%\")\n",
    "\n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"SUMMARY\")\n",
    "    if guided_mean > random_mean:\n",
    "        print(f\"  PASS: surrogate-guided proposal outperforms random search\")\n",
    "        print(f\"  by {improvement:.1f}% under equal evaluation budget.\")\n",
    "        print(f\"  This supports Claim 1's core mechanism at toy scale.\")\n",
    "    else:\n",
    "        print(f\"  FAIL: surrogate-guided proposal did NOT outperform random search\")\n",
    "        print(f\"  in this toy setting.\")\n",
    "    print(\"=\" * 70)\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()"
